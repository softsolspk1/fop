// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-1.0.x", "rhel-openssl-1.1.x", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  DEPT_ADMIN
  TEACHER
  STUDENT
}

enum EnrollmentStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id               String           @id @default(uuid())
  email            String           @unique
  password         String
  name             String
  role             Role             @default(STUDENT)
  status           EnrollmentStatus @default(PENDING)
  departmentId     String?
  department       Department?      @relation(fields: [departmentId], references: [id])
  hodOf            Department[]     @relation("DeptHOD")
  attendances      Attendance[]
  submissions      Submission[]
  grades           Grade[]
  teacherCourses   Course[]         @relation("TeacherCourses")
  studentCourses   Course[]         @relation("StudentCourses")
  resultsPosted    Result[]         @relation("ResultTeacher")
  studentResults   Result[]         @relation("ResultStudent")
  rollNumber       String?
  shift            String?          // MORNING or EVENING
  year             Int?             // 1, 2, 3, 4, 5
  fees             Fee[]
  examResults      ExamResult[]
  quizzes          QuizResult[]
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
}

model Result {
  id           String   @id @default(uuid())
  studentId    String
  student      User     @relation("ResultStudent", fields: [studentId], references: [id])
  courseId     String
  course       Course   @relation(fields: [courseId], references: [id])
  teacherId    String
  teacher      User     @relation("ResultTeacher", fields: [teacherId], references: [id])
  marks        Float
  grade        String
  semester     Int
  academicYear String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}


model Fee {
  id          String   @id @default(uuid())
  title       String
  amount      Float
  dueDate     DateTime
  status      String   // 'UNPAID', 'PAID', 'OVERDUE'
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Exam {
  id          String   @id @default(uuid())
  title       String
  date        DateTime
  location    String?
  courseId    String
  course      Course   @relation(fields: [courseId], references: [id])
  results     ExamResult[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ExamResult {
  id        String   @id @default(uuid())
  score     Float
  grade     String?
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  examId    String
  exam      Exam     @relation(fields: [examId], references: [id])
  createdAt DateTime @default(now())
}

model Department {
  id        String   @id @default(uuid())
  name      String   @unique
  hodId     String?  // Head of Department
  hod       User?    @relation("DeptHOD", fields: [hodId], references: [id])
  courses   Course[]
  users     User[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Semester {
  id        String   @id @default(uuid())
  name      String   @unique // e.g., 'Fall 2025', 'Spring 2026'
  startDate DateTime
  endDate   DateTime
  courses   Course[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Course {
  id           String   @id @default(uuid())
  name         String
  code         String   @unique
  departmentId String
  department   Department @relation(fields: [departmentId], references: [id])
  semesterId   String?
  semester     Semester?  @relation(fields: [semesterId], references: [id])
  teacherId    String
  teacher      User     @relation("TeacherCourses", fields: [teacherId], references: [id])
  students     User[]   @relation("StudentCourses")
  materials    Material[]
  assignments  Assignment[]
  quizzes      Quiz[]
  classes      Class[]
  exams        Exam[]
  results      Result[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Material {
  id        String   @id @default(uuid())
  title     String
  url       String   // Google Drive URL
  type      String   // e.g., 'LECTURE_NOTE', 'VIDEO', 'SLIDE'
  courseId  String
  course    Course   @relation(fields: [courseId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Class {
  id           String   @id @default(uuid())
  title        String
  startTime    DateTime
  endTime      DateTime
  agoraChannel String?
  courseId     String
  course       Course   @relation(fields: [courseId], references: [id])
  attendance   Attendance[]
  recordings   Recording[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Attendance {
  id        String   @id @default(uuid())
  status    String   // 'PRESENT', 'ABSENT', 'LATE'
  remarks   String?
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  classId   String
  class     Class    @relation(fields: [classId], references: [id])
  createdAt DateTime @default(now())
}

model Assignment {
  id          String   @id @default(uuid())
  title       String
  description String
  dueDate     DateTime
  courseId    String
  course      Course   @relation(fields: [courseId], references: [id])
  submissions Submission[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Submission {
  id           String   @id @default(uuid())
  fileUrl      String   // Google Drive URL
  status       String   // 'SUBMITTED', 'GRADED'
  plagiarism   Float?   // Plagiarism percentage
  assignmentId String
  assignment   Assignment @relation(fields: [assignmentId], references: [id])
  studentId    String
  student      User       @relation(fields: [studentId], references: [id])
  grade        Grade?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Quiz {
  id          String   @id @default(uuid())
  title       String
  description String?
  timeLimit   Int      // in minutes
  courseId    String
  course      Course   @relation(fields: [courseId], references: [id])
  questions   Question[]
  results     QuizResult[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Question {
  id        String   @id @default(uuid())
  text      String
  options   String[] // JSON array of options
  answer    String
  quizId    String
  quiz      Quiz     @relation(fields: [quizId], references: [id])
}

model QuizResult {
  id        String   @id @default(uuid())
  score     Float
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  quizId    String
  quiz      Quiz     @relation(fields: [quizId], references: [id])
  createdAt DateTime @default(now())
}

model Grade {
  id           String   @id @default(uuid())
  score        Float
  feedback     String?
  submissionId String   @unique
  submission   Submission @relation(fields: [submissionId], references: [id])
  teacherId    String
  teacher      User       @relation(fields: [teacherId], references: [id])
  createdAt    DateTime @default(now())
}

model Recording {
  id        String   @id @default(uuid())
  url       String   // Agora recording or Google Drive storage URL
  transcript String? // AI generated transcript
  classId   String
  class     Class    @relation(fields: [classId], references: [id])
  createdAt DateTime @default(now())
}

model Lab {
  id          String   @id @default(uuid())
  title       String
  description String
  department  String
  provider    String
  difficulty  String   // 'Beginner', 'Intermediate', 'Advanced'
  url         String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model FacultyMember {
  id          String   @id @default(uuid())
  name        String
  designation String
  department  String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
