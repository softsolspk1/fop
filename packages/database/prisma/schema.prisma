generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-1.0.x", "rhel-openssl-1.1.x", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String             @id @default(uuid())
  email             String             @unique
  password          String
  name              String
  role              Role               @default(STUDENT)
  departmentId      String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  rollNumber        String?
  shift             String?
  status            EnrollmentStatus   @default(PENDING)
  year              String?
  enrollmentNumber  String?
  phoneNumber       String?
  assessmentResults AssessmentResult[]
  attendances       Attendance[]
  teacherCourses    Course[]           @relation("TeacherCourses")
  hodOf             Department[]       @relation("DeptHOD")
  examResults       ExamResult[]
  experiments       Experiment[]
  fees              Fee[]
  grades            Grade[]
  receivedMessages  Message[]          @relation("ReceivedMessages")
  sentMessages      Message[]          @relation("SentMessages")
  quizzes           QuizResult[]
  studentResults    Result[]           @relation("ResultStudent")
  resultsPosted     Result[]           @relation("ResultTeacher")
  submissions       Submission[]
  department        Department?        @relation(fields: [departmentId], references: [id])
  groups            ChatGroup[]        @relation("GroupMembers")
  studentCourses    Course[]           @relation("StudentCourses")
  labObservations   LabObservation[]
  uploadedMaterials Material[]         @relation("MaterialUploader")
  
  // Faculty Profile Fields
  designation       String?
  qualification     String?
  bio               String?
  yearOfAssociation String?
}

model Result {
  id           String   @id @default(uuid())
  studentId    String
  courseId     String
  teacherId    String
  marks        Float
  grade        String
  semester     Int
  academicYear String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  course       Course   @relation(fields: [courseId], references: [id])
  student      User     @relation("ResultStudent", fields: [studentId], references: [id])
  teacher      User     @relation("ResultTeacher", fields: [teacherId], references: [id])
}

model Fee {
  id        String   @id @default(uuid())
  title     String
  amount    Float
  dueDate   DateTime
  status    String
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])
}

model Exam {
  id        String       @id @default(uuid())
  title     String
  date      DateTime
  location  String?
  courseId  String
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  course    Course       @relation(fields: [courseId], references: [id])
  results   ExamResult[]
}

model ExamResult {
  id        String   @id @default(uuid())
  score     Float
  grade     String?
  userId    String
  examId    String
  createdAt DateTime @default(now())
  exam      Exam     @relation(fields: [examId], references: [id])
  user      User     @relation(fields: [userId], references: [id])
}

model Department {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  hodId     String?
  courses   Course[]
  hod       User?    @relation("DeptHOD", fields: [hodId], references: [id])
  users     User[]
}

model Semester {
  id        String   @id @default(uuid())
  name      String   @unique
  startDate DateTime
  endDate   DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  courses   Course[]
}

model Course {
  id           String       @id @default(uuid())
  name         String
  code         String       @unique
  departmentId String
  teacherId    String
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  semesterId   String?
  assignments  Assignment[]
  chatGroup    ChatGroup?
  classes      Class[]
  department   Department   @relation(fields: [departmentId], references: [id])
  semester     Semester?    @relation(fields: [semesterId], references: [id])
  teacher      User         @relation("TeacherCourses", fields: [teacherId], references: [id])
  exams        Exam[]
  labs         Lab[]
  materials    Material[]
  quizzes      Quiz[]
  results      Result[]
  students     User[]       @relation("StudentCourses")

  // Academic Metadata
  professional String?      // e.g. "First", "Second"
  semesterName String?      // e.g. "1st Semester"
  creditHours  String?
  category     String?      // e.g. "Core", "General"
  outcomes     String?      @db.Text
  contents     String?      @db.Text
  readings     String?      @db.Text
  isActive     Boolean      @default(true)
}

model Material {
  id           String           @id @default(uuid())
  title        String
  url          String
  type         String           // IMAGE, VIDEO, DOCUMENT, YOUTUBE
  courseId     String
  uploadedById String?
  publicId     String?
  status       EnrollmentStatus @default(PENDING) // Reusing EnrollmentStatus for simplicity: PENDING, APPROVED, REJECTED
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  course       Course           @relation(fields: [courseId], references: [id])
  uploadedBy   User?            @relation("MaterialUploader", fields: [uploadedById], references: [id])
}

model Class {
  id               String       @id @default(uuid())
  title            String
  startTime        DateTime
  endTime          DateTime
  actualStartTime  DateTime?    // When the teacher Actually clicks "Start Session"
  actualEndTime    DateTime?    // When the teacher Actually clicks "Stop Session"
  agoraChannel     String?
  courseId         String
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  dayOfWeek        String       @default("Monday")
  location         String       @default("Lecture Hall 1")
  classType        String       @default("Physical") // Online, Physical
  
  attendance   Attendance[]
  course       Course       @relation(fields: [courseId], references: [id])
  recordings   Recording[]
}

model Attendance {
  id             String    @id @default(uuid())
  status         String    // PRESENT, ABSENT, LATE
  userId         String
  classId        String
  markedStartAt  DateTime? // First attendance mark within 15 mins
  markedEndAt    DateTime? // Second attendance mark within 5 mins
  createdAt      DateTime  @default(now())
  remarks        String?
  class          Class     @relation(fields: [classId], references: [id])
  user           User      @relation(fields: [userId], references: [id])

  @@unique([userId, classId])
}

model Assignment {
  id          String       @id @default(uuid())
  title       String
  description String
  startTime   DateTime?
  endTime     DateTime?
  dueDate     DateTime?  // Re-adding dueDate for compatibility
  totalMarks  Float?
  fileUrl     String?
  publicId    String?
  courseId    String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  course      Course       @relation(fields: [courseId], references: [id])
  submissions Submission[]
}

model Submission {
  id           String     @id @default(uuid())
  fileUrl      String
  publicId     String?
  status       String
  plagiarism   Float?
  assignmentId String
  studentId    String
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  grade        Grade?
  assignment   Assignment @relation(fields: [assignmentId], references: [id])
  student      User       @relation(fields: [studentId], references: [id])
}

model Quiz {
  id          String           @id @default(uuid())
  title             String
  description       String?
  startTime         DateTime?
  endTime           DateTime?
  totalMarks        Float     @default(100)
  passingPercentage Float     @default(50)
  timeLimit         Int
  courseId          String
  status            EnrollmentStatus @default(PENDING)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  questions   Question[]
  course      Course           @relation(fields: [courseId], references: [id])
  results     QuizResult[]
}

model Question {
  id      String   @id @default(uuid())
  text    String
  options String[]
  answer  String
  quizId  String
  quiz    Quiz     @relation(fields: [quizId], references: [id])
}

model QuizResult {
  id        String   @id @default(uuid())
  score     Float
  passed    Boolean  @default(false)
  userId    String
  quizId    String
  createdAt DateTime @default(now())
  quiz      Quiz     @relation(fields: [quizId], references: [id])
  user      User     @relation(fields: [userId], references: [id])
}

model Grade {
  id           String     @id @default(uuid())
  score        Float
  feedback     String?
  submissionId String     @unique
  teacherId    String
  createdAt    DateTime   @default(now())
  submission   Submission @relation(fields: [submissionId], references: [id])
  teacher      User       @relation(fields: [teacherId], references: [id])
}

model Recording {
  id         String   @id @default(uuid())
  url        String
  transcript String?
  classId    String
  createdAt  DateTime @default(now())
  class      Class    @relation(fields: [classId], references: [id])
}

model Lab {
  id          String       @id @default(uuid())
  title       String       @unique
  description String
  department  String
  provider    String
  difficulty  String
  url         String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  objectives  String?
  safety      String?
  theory      String?
  courseId    String?
  year        String?
  assessments Assessment[]
  experiments Experiment[]
  course      Course?      @relation(fields: [courseId], references: [id])
  multimediaContent Json?
}

model Experiment {
  id           String        @id @default(uuid())
  labId        String
  studentId    String
  status       String
  inputs       Json?
  resultData   Json?
  grade        Float?
  feedback     String?
  createdAt    DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  studentResult      Json?
  studentObservation Json?
  lab                Lab           @relation(fields: [labId], references: [id])
  student      User          @relation(fields: [studentId], references: [id])
  observations Observation[]
}

model Observation {
  id           String     @id @default(uuid())
  experimentId String
  timeStep     Float?
  reading      Float
  notes        String?
  createdAt    DateTime   @default(now())
  experiment   Experiment @relation(fields: [experimentId], references: [id])
}

model Assessment {
  id        String             @id @default(uuid())
  labId     String
  questions Json
  createdAt DateTime           @default(now())
  lab       Lab                @relation(fields: [labId], references: [id])
  results   AssessmentResult[]
}

model LabObservation {
  id        String   @id @default(uuid())
  userId    String
  labType   String
  data      Json
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model AssessmentResult {
  id           String     @id @default(uuid())
  assessmentId String
  studentId    String
  score        Float
  answers      Json
  createdAt    DateTime   @default(now())
  assessment   Assessment @relation(fields: [assessmentId], references: [id])
  student      User       @relation(fields: [studentId], references: [id])
}

model FacultyMember {
  id          String   @id @default(uuid())
  name        String
  designation String
  department  String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Message {
  id         String     @id @default(uuid())
  content    String
  senderId   String
  receiverId String?
  groupId    String?
  createdAt  DateTime   @default(now())
  group      ChatGroup? @relation(fields: [groupId], references: [id])
  receiver   User?      @relation("ReceivedMessages", fields: [receiverId], references: [id])
  sender     User       @relation("SentMessages", fields: [senderId], references: [id])
}

model ChatGroup {
  id          String    @id @default(uuid())
  name        String
  description String?
  courseId    String?   @unique
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  course      Course?   @relation(fields: [courseId], references: [id])
  messages    Message[]
  members     User[]    @relation("GroupMembers")
}

enum Role {
  SUPER_ADMIN
  DEPT_ADMIN
  TEACHER
  STUDENT
}

enum EnrollmentStatus {
  PENDING
  APPROVED
  REJECTED
}
