{
  "name": "ku-app-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/web",
    "apps/mobile",
    "packages/api",
    "packages/database"
  ],
  "scripts": {
    "dev": "npm run dev --workspaces --if-present",
    "build:all": "npm run build --workspaces --if-present",
    "build:web": "cd apps/web && npx next build",
    "postinstall": "npx prisma@6.19.2 generate --schema=packages/database/prisma/schema.prisma",
    "test": "npm run test --workspaces --if-present"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "prisma": "^6.19.2",
    "next": "16.1.6",
    "@tailwindcss/postcss": "^4",
    "lightningcss": "^1.31.1",
    "tailwindcss": "^4"
  },
  "dependencies": {
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "@prisma/client": "^6.19.2"
  },
  "overrides": {
    "metro": "0.80.12",
    "metro-config": "0.80.12"
  }
}
