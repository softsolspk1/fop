{
  "name": "ku-app-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/web",
    "apps/mobile",
    "packages/api",
    "packages/database"
  ],
  "scripts": {
    "dev": "npm run dev --workspaces --if-present",
    "build:all": "npm run build --workspaces --if-present",
    "build:web": "cd apps/web && npx next build",
    "postinstall": "npx prisma@6.19.2 generate --schema=packages/database/prisma/schema.prisma && node build-scripts/patch-metro.js",
    "test": "npm run test --workspaces --if-present"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "lightningcss": "^1.31.1",
    "next": "16.1.6",
    "prisma": "^6.19.2",
    "tailwindcss": "^4",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "@prisma/client": "^6.19.2",
    "expo-router": "~4.0.22",
    "pdf-parse": "^2.4.5",
    "react-native": "0.76.9",
    "regenerator-runtime": "^0.14.1",
    "core-js": "^3.36.0"
  },
  "overrides": {
    "react-native": "0.76.9",
    "expo-router": "~4.0.22",
    "react-native-screens": "~4.7.0",
    "@react-native-async-storage/async-storage": "1.23.1",
    "react-native-svg": "~15.8.0"
  }
}
